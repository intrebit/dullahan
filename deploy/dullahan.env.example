DATABASE_URL=postgres://dullahan:CHANGEME@127.0.0.1:5432/dullahan
BIND_ADDR=127.0.0.1:3011
# Comma-separated list of accepted site IDs. Leave unset to accept any site.
# ALLOWED_SITES=fole.dev,openbenchmark.dev
# Required to read /stats/*. Generate with: openssl rand -hex 24
# If unset, /stats/* is publicly readable (NOT recommended for the public internet).
ADMIN_TOKEN=
# Comma-separated list of origins allowed to call /stats/*. Unset = any origin.
# Set to your dashboard URL so a browser elsewhere can't read responses even
# if the admin token leaks into a page.
# STATS_ORIGINS=https://stats.example.com
# Set to 1 once the deploy is fronted by HTTPS so HSTS is sent.
# BEHIND_TLS=1
# Opt-in anonymized sessions (unique visitors, bounce rate, browser/OS family).
# Off by default: with it off the server reads neither client IP nor User-Agent.
# SESSIONS_ENABLED=1
# Log format: text (default) or json (structured).
# LOG_FORMAT=json
RUST_LOG=info,sqlx=warn
# RESEND_API_KEY=re_...
# EMAIL_FROM=noreply@example.com
# EMAIL_FROM_NAME=dullahan
# Recipient for POST /contact — without this the endpoint returns 503.
# CONTACT_TO=hello@example.com
